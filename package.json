{
  "name": "0xmarkets-squid",
  "version": "1.0.0",
  "description": "Subsquid indexer for 0xMarkets protocol",
  "private": true,
  "scripts": {
    "build": "rm -rf lib && tsc",
    "codegen": "squid-typeorm-codegen",
    "typegen": "squid-evm-typegen src/abi ./abi/*.json --multicall",
    "process": "node lib/main.js",
    "process:prod": "node lib/main.js",
    "serve": "squid-graphql-server",
    "serve:prod": "squid-graphql-server",
    "migration:generate": "squid-typeorm-migration generate",
    "migration:apply": "squid-typeorm-migration apply",
    "db:reset": "sqd down && sqd up && sqd migration:apply",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@subsquid/evm-processor": "^1.19.0",
    "@subsquid/graphql-server": "^4.7.0",
    "@subsquid/ss58": "^2.0.2",
    "@subsquid/typeorm-migration": "^1.3.0",
    "@subsquid/typeorm-store": "^1.5.1",
    "dotenv": "^17.2.3",
    "ethers": "^6.9.0",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@subsquid/evm-typegen": "^4.3.0",
    "@subsquid/typeorm-codegen": "^2.0.2",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
